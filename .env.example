GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-live-001
GEMINI_VOICE=Aoede
ADMIN_PASSWORD=
# Comma-separated list of allowed CORS origins (your frontend domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional: override data directory path
DATA_DIR=
# Optional: inline scene map JSON (fallback if data/scenes.json not found)
SCENE_MAP_JSON={}

# RAG
RAG_ENABLED=true
RAG_DOCS_DIR=./data/rag_docs
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# Firebase Chat History
FIREBASE_CREDENTIALS_JSON=./firebase-service-account.json
# Or use base64-encoded JSON (alternative to file path):
# FIREBASE_CREDENTIALS_BASE64=
FIREBASE_PROJECT_ID=your-project-id
CHAT_HISTORY_ENABLED=true
PROJECT_NAME=realestate-chatbot
